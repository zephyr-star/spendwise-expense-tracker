# SpendWise Environment Configuration
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-64-char-random-string
JWT_SECRET_KEY=change-me-to-another-64-char-random-string
ENCRYPTION_KEY=change-me-fernet-key-base64-44chars==
POSTGRES_PASSWORD=change-me-strong-db-password

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://spendwise:${POSTGRES_PASSWORD}@postgres:5432/spendwise

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Object Storage ────────────────────────────────────────────────────────────
STORAGE_BACKEND=s3                      # s3 | gcs | local
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
S3_BUCKET_RECEIPTS=spendwise-receipts

# ── OCR Backend ───────────────────────────────────────────────────────────────
OCR_BACKEND=tesseract                   # tesseract | google_vision | aws_textract

# ── Push Notifications ────────────────────────────────────────────────────────
FIREBASE_SERVER_KEY=your-firebase-server-key
FIREBASE_PROJECT_ID=your-firebase-project

# ── Cloud ML (optional) ───────────────────────────────────────────────────────
CLOUD_ML_ENABLED=false
CLOUD_ML_ENDPOINT=https://your-ml-endpoint.com/predict

# ── Exchange Rates ────────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key

# ── Observability (optional) ──────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
GRAFANA_PASSWORD=change-me-grafana-password

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["https://your-app-domain.com","capacitor://localhost"]